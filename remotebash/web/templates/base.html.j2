<!DOCTYPE html>
<html lang="zh-CN" class="scroll-smooth">
<head>
  <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 32 32'><rect width='32' height='32' rx='6' fill='%230f1117'/><text x='50%25' y='53%25' dominant-baseline='middle' text-anchor='middle' font-family='monospace' font-size='18' font-weight='bold' fill='%2358a6ff'>▶</text></svg>"/>
  <meta name="viewport" content="width=device-width,initial-scale=1.0">
  <title>{% block title %}RemoteBash{% endblock %}</title>
  <script src="{{ url_for('static', path='tailwind.js') }}"></script>
  <script>
    tailwind.config = {
      darkMode: 'class',
      theme: {
        extend: {
          colors: {
            surface: { DEFAULT: '#0f1117', raised: '#1a1d27', overlay: '#222533' },
            border: { DEFAULT: '#2a2d3a', hover: '#3a3d4a' },
            accent: { DEFAULT: '#58a6ff', hover: '#4090e0' },
            muted: '#8b949e',
            green: '#3fb950',
            red: '#f85149',
            yellow: '#d2991d',
          }
        }
      }
    }
  </script>
  <style>
    /* 强制浏览器以暗色模式渲染原生日期/时间控件 */
    input[type="datetime-local"] {
      color-scheme: dark;
    }
    /* 日期控件 placeholder 占位文字颜色 */
    input[type="datetime-local"]::-webkit-datetime-edit-text,
    input[type="datetime-local"]::-webkit-datetime-edit-month-field,
    input[type="datetime-local"]::-webkit-datetime-edit-day-field,
    input[type="datetime-local"]::-webkit-datetime-edit-year-field,
    input[type="datetime-local"]::-webkit-datetime-edit-hour-field,
    input[type="datetime-local"]::-webkit-datetime-edit-minute-field {
      color: #8b949e;
    }
    /* 日历/时钟图标 */
    input[type="datetime-local"]::-webkit-calendar-picker-indicator {
      filter: invert(0.7);
    }
    /* 已设值时的文字颜色 */
    input[type="datetime-local"]::-webkit-datetime-edit-fields-wrapper {
      color: #e2e8f0;
    }
  </style>
  {% block head_extra %}{% endblock %}
</head>
<body class="bg-surface text-gray-200 min-h-screen font-sans antialiased">
  {% block body %}{% endblock %}
  <div id="toast" class="fixed top-5 right-5 z-50 bg-surface-overlay border border-border rounded-xl px-5 py-3 text-sm shadow-2xl opacity-0 translate-y-2 transition-all duration-300 pointer-events-none"></div>
  {% block scripts %}{% endblock %}
</body>
</html>
